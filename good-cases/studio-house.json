{
    "globalCssTokens": {
        "base": {
            "--transition-smooth": "0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
            "--transition-slow": "0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
            "--border-radius-sm": "0.5rem",
            "--border-radius-md": "1rem",
            "--border-radius-lg": "2rem",
            "--border-radius-xl": "3rem",
            "--font-main": "'Manrope', -apple-system, BlinkMacSystemFont, sans-serif",
            "--font-display": "'Cormorant Garamond', Georgia, serif",
            "--container-width": "1320px"
        },
        "light": {
            "--primary": "#1a1a1a",
            "--primary-light": "#333333",
            "--accent": "#c6a15b",
            "--accent-soft": "#f5efe6",
            "--background": "#ffffff",
            "--background-alt": "#fafafa",
            "--surface": "#ffffff",
            "--text-main": "#171717",
            "--text-muted": "#666666",
            "--text-light": "#999999",
            "--border-light": "#eaeaea",
            "--border-medium": "#d4d4d4",
            "--shadow-sm": "0 4px 12px rgba(0, 0, 0, 0.02)",
            "--shadow-elevated": "0 24px 48px -12px rgba(0, 0, 0, 0.08)",
            "--shadow-luxury": "0 40px 80px -20px rgba(198, 161, 91, 0.12)",
            "--gradient-luxury": "linear-gradient(145deg, #ffffff 0%, #faf8f5 100%)"
        },
        "dark": {
            "--primary": "#f5f5f5",
            "--primary-light": "#cccccc",
            "--accent": "#d4b87a",
            "--accent-soft": "#2a2520",
            "--background": "#0c0c0c",
            "--background-alt": "#141414",
            "--surface": "#1a1a1a",
            "--text-main": "#f0f0f0",
            "--text-muted": "#a0a0a0",
            "--text-light": "#707070",
            "--border-light": "#2a2a2a",
            "--border-medium": "#3a3a3a",
            "--shadow-sm": "0 4px 12px rgba(0, 0, 0, 0.3)",
            "--shadow-elevated": "0 24px 48px -12px rgba(0, 0, 0, 0.5)",
            "--shadow-luxury": "0 40px 80px -20px rgba(212, 184, 122, 0.05)",
            "--gradient-luxury": "linear-gradient(145deg, #1a1a1a 0%, #111111 100%)"
        }
    },
    "sections": {
        "Header": {
            "styles": {
                "HeaderWrapper": {
                    "__html": "header",
                    "position": "sticky",
                    "top": "0",
                    "z-index": "100",
                    "background": "rgba(255, 255, 255, 0.7)",
                    "backdrop-filter": "blur(20px)",
                    "border-bottom": "1px solid var(--border-light)",
                    "padding": "1.25rem 2rem",
                    "font-family": "var(--font-main)"
                },
                "HeaderContainer": {
                    "__html": "nav",
                    "max-width": "var(--container-width)",
                    "margin": "0 auto",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "space-between"
                },
                "LogoContainer": {
                    "__html": "div",
                    "display": "flex",
                    "align-items": "baseline",
                    "gap": "0.25rem"
                },
                "LogoMain": {
                    "__html": "span",
                    "font-family": "var(--font-display)",
                    "font-size": "2rem",
                    "font-weight": "600",
                    "color": "var(--text-main)",
                    "letter-spacing": "-0.02em",
                    "line-height": "1"
                },
                "LogoAccent": {
                    "__html": "span",
                    "width": "0.5rem",
                    "height": "0.5rem",
                    "background": "var(--accent)",
                    "border-radius": "50%",
                    "display": "inline-block",
                    "margin-left": "0.25rem"
                },
                "NavList": {
                    "__html": "ul",
                    "display": "flex",
                    "gap": "3rem",
                    "list-style": "none",
                    "margin": "0",
                    "padding": "0"
                },
                "NavItem": {
                    "__html": "li",
                    "color": "var(--text-main)",
                    "font-weight": "500",
                    "font-size": "0.95rem",
                    "letter-spacing": "0.5px",
                    "cursor": "pointer",
                    "text-transform": "uppercase",
                    "transition": "color var(--transition-smooth)",
                    "border-bottom": "2px solid transparent",
                    "padding-bottom": "0.5rem"
                },
                "HeaderAction": {
                    "__html": "button",
                    "background": "transparent",
                    "color": "var(--text-main)",
                    "border": "1px solid var(--border-medium)",
                    "border-radius": "var(--border-radius-full)",
                    "padding": "0.75rem 2rem",
                    "font-weight": "500",
                    "font-size": "0.9rem",
                    "cursor": "pointer",
                    "transition": "all var(--transition-smooth)",
                    "font-family": "var(--font-main)",
                    "text-transform": "uppercase",
                    "letter-spacing": "1px"
                }
            },
            "mainContent": {
                "HeaderWrapper": {
                    "HeaderContainer": {
                        "LogoContainer": {
                            "LogoMain": {
                                "content": "AURELIA"
                            },
                            "LogoAccent": {
                                "content": ""
                            }
                        },
                        "NavList": {
                            "NavItem": {
                                "content": "Объекты"
                            },
                            "NavItem": {
                                "content": "Продавцам"
                            },
                            "NavItem": {
                                "content": "О нас"
                            },
                            "NavItem": {
                                "content": "Контакты"
                            }
                        },
                        "HeaderAction": {
                            "content": "Заказать звонок"
                        }
                    }
                }
            }
        },
        "Hero": {
            "styles": {
                "HeroSection": {
                    "__html": "section",
                    "width": "100%",
                    "min-height": "90vh",
                    "display": "flex",
                    "align-items": "center",
                    "padding": "6rem 2rem",
                    "background": "var(--gradient-luxury)",
                    "position": "relative",
                    "overflow": "hidden",
                    "font-family": "var(--font-main)"
                },
                "HeroContainer": {
                    "__html": "div",
                    "max-width": "var(--container-width)",
                    "margin": "0 auto",
                    "display": "grid",
                    "grid-template-columns": "1fr 1fr",
                    "gap": "6rem",
                    "align-items": "center",
                    "width": "100%"
                },
                "HeroContent": {
                    "__html": "div",
                    "display": "flex",
                    "flex-direction": "column",
                    "gap": "2rem"
                },
                "HeroEyebrow": {
                    "__html": "span",
                    "color": "var(--accent)",
                    "text-transform": "uppercase",
                    "letter-spacing": "4px",
                    "font-size": "0.85rem",
                    "font-weight": "500"
                },
                "HeroTitle": {
                    "__html": "h1",
                    "font-family": "var(--font-display)",
                    "font-size": "clamp(3.5rem, 7vw, 5.5rem)",
                    "font-weight": "500",
                    "line-height": "1.1",
                    "color": "var(--text-main)",
                    "margin": "0",
                    "letter-spacing": "-0.02em"
                },
                "HeroDescription": {
                    "__html": "p",
                    "font-size": "1.2rem",
                    "line-height": "1.7",
                    "color": "var(--text-muted)",
                    "margin": "0",
                    "max-width": "90%"
                },
                "HeroDivider": {
                    "__html": "hr",
                    "width": "120px",
                    "height": "2px",
                    "background": "var(--accent)",
                    "border": "none",
                    "margin": "1rem 0"
                },
                "HeroStats": {
                    "__html": "div",
                    "display": "flex",
                    "gap": "3rem",
                    "margin-top": "1rem"
                },
                "StatItem": {
                    "__html": "div",
                    "display": "flex",
                    "flex-direction": "column",
                    "gap": "0.25rem"
                },
                "StatValue": {
                    "__html": "span",
                    "font-family": "var(--font-display)",
                    "font-size": "2.5rem",
                    "font-weight": "500",
                    "color": "var(--text-main)"
                },
                "StatLabel": {
                    "__html": "span",
                    "color": "var(--text-muted)",
                    "font-size": "0.9rem",
                    "text-transform": "uppercase",
                    "letter-spacing": "1px"
                },
                "HeroVisual": {
                    "__html": "div",
                    "background": "var(--primary-light)",
                    "border-radius": "var(--border-radius-md)",
                    "height": "600px",
                    "width": "100%",
                    "position": "relative",
                    "box-shadow": "var(--shadow-luxury)",
                    "border": "1px solid var(--border-light)"
                },
                "PrimaryButton": {
                    "__html": "button",
                    "background": "var(--primary)",
                    "color": "white",
                    "border": "none",
                    "border-radius": "var(--border-radius-full)",
                    "padding": "1.25rem 3rem",
                    "font-weight": "500",
                    "font-size": "1rem",
                    "cursor": "pointer",
                    "transition": "all var(--transition-smooth)",
                    "text-transform": "uppercase",
                    "letter-spacing": "2px",
                    "width": "fit-content"
                }
            },
            "mainContent": {
                "HeroSection": {
                    "HeroContainer": {
                        "HeroContent": {
                            "HeroEyebrow": {
                                "content": "Искусство жить красиво"
                            },
                            "HeroTitle": {
                                "content": "Пространство, которое вдохновляет"
                            },
                            "HeroDivider": {
                                "content": ""
                            },
                            "HeroDescription": {
                                "content": "Aurelia Estate — бутик-агентство премиальной недвижимости. Откройте двери в мир исключительных интерьеров и архитектурных шедевров."
                            },
                            "HeroStats": {
                                "StatItem": {
                                    "StatValue": {
                                        "content": "250+"
                                    },
                                    "StatLabel": {
                                        "content": "Закрытых сделок"
                                    }
                                },
                                "StatItem": {
                                    "StatValue": {
                                        "content": "15 лет"
                                    },
                                    "StatLabel": {
                                        "content": "На рынке"
                                    }
                                }
                            },
                            "PrimaryButton": {
                                "content": "Подобрать объект"
                            }
                        },
                        "HeroVisual": {
                            "content": " "
                        }
                    }
                }
            }
        },
        "Partners": {

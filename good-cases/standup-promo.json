{
    "globalCssTokens": {
        "base": {
            "--transition-fast": "0.15s cubic-bezier(0.4, 0, 0.2, 1)",
            "--transition-smooth": "0.3s cubic-bezier(0.4, 0, 0.2, 1)",
            "--transition-bounce": "0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55)",
            "--border-radius-sm": "0.5rem",
            "--border-radius-md": "1rem",
            "--border-radius-lg": "2rem",
            "--border-radius-xl": "3rem",
            "--border-radius-full": "9999px",
            "--font-main": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
            "--font-display": "'Bebas Neue', 'Impact', sans-serif",
            "--font-decor": "'Comic Sans MS', cursive",
            "--container-width": "1280px"
        },
        "light": {
            "--primary": "#1a1a2e",
            "--primary-light": "#16213e",
            "--accent": "#e94560",
            "--accent-glow": "#ff6b81",
            "--accent-secondary": "#533483",
            "--accent-tertiary": "#f5a623",
            "--background": "#ffffff",
            "--background-alt": "#f8f9fa",
            "--surface": "#ffffff",
            "--surface-dark": "#1a1a2e",
            "--text-main": "#1a1a2e",
            "--text-muted": "#4a4a5e",
            "--text-light": "#8a8a9e",
            "--text-inverse": "#ffffff",
            "--border-light": "#e0e0e0",
            "--border-accent": "#e94560",
            "--shadow-sm": "0 4px 12px rgba(26, 26, 46, 0.06)",
            "--shadow-md": "0 12px 28px rgba(26, 26, 46, 0.1)",
            "--shadow-lg": "0 24px 48px rgba(26, 26, 46, 0.15)",
            "--shadow-neon": "0 0 30px rgba(233, 69, 96, 0.4)",
            "--gradient-hero": "linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)",
            "--gradient-accent": "linear-gradient(135deg, #e94560 0%, #ff6b81 100%)",
            "--gradient-purple": "linear-gradient(135deg, #533483 0%, #7b4fba 100%)",
            "--pattern-dots": "radial-gradient(circle at 2px 2px, rgba(233, 69, 96, 0.15) 1px, transparent 1px)",
            "--pattern-lines": "repeating-linear-gradient(45deg, rgba(0,0,0,0.02) 0px, rgba(0,0,0,0.02) 2px, transparent 2px, transparent 8px)"
        },
        "dark": {
            "--primary": "#e94560",
            "--primary-light": "#ff6b81",
            "--accent": "#f5a623",
            "--accent-glow": "#ffc107",
            "--accent-secondary": "#7b4fba",
            "--accent-tertiary": "#00d2ff",
            "--background": "#0f0f1a",
            "--background-alt": "#1a1a2e",
            "--surface": "#16213e",
            "--surface-dark": "#0a0a15",
            "--text-main": "#ffffff",
            "--text-muted": "#b0b0c0",
            "--text-light": "#707080",
            "--text-inverse": "#1a1a2e",
            "--border-light": "#2a2a40",
            "--border-accent": "#f5a623",
            "--shadow-sm": "0 4px 12px rgba(0, 0, 0, 0.3)",
            "--shadow-md": "0 12px 28px rgba(0, 0, 0, 0.4)",
            "--shadow-lg": "0 24px 48px rgba(0, 0, 0, 0.5)",
            "--shadow-neon": "0 0 40px rgba(245, 166, 35, 0.5)",
            "--gradient-hero": "linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 100%)",
            "--gradient-accent": "linear-gradient(135deg, #f5a623 0%, #ffc107 100%)",
            "--gradient-purple": "linear-gradient(135deg, #533483 0%, #7b4fba 100%)",
            "--pattern-dots": "radial-gradient(circle at 2px 2px, rgba(245, 166, 35, 0.2) 1px, transparent 1px)",
            "--pattern-lines": "repeating-linear-gradient(45deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 2px, transparent 2px, transparent 8px)"
        }
    },
    "sections": {
        "Header": {
            "styles": {
                "HeaderWrapper": {
                    "__html": "header",
                    "base": {
                        "position": "fixed",
                        "top": "0",
                        "left": "0",
                        "right": "0",
                        "z-index": "100",
                        "background": "var(--background)",
                        "border-bottom": "2px solid var(--border-accent)",
                        "font-family": "var(--font-main)",
                        "box-shadow": "var(--shadow-sm)"
                    },
                    "mobile": {
                        "background": "rgba(255, 255, 255, 0.95)",
                        "backdrop-filter": "blur(8px)"
                    }
                },
                "HeaderContainer": {
                    "__html": "div",
                    "base": {
                        "max-width": "var(--container-width)",
                        "margin": "0 auto",
                        "padding": "1rem 2rem",
                        "display": "flex",
                        "align-items": "center",
                        "justify-content": "space-between"
                    },
                    "mobile": {
                        "padding": "0.75rem 1rem"
                    }
                },
                "LogoContainer": {
                    "__html": "div",

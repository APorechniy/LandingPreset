                },
                "HeroContent": {
                    "__html": "div",
                    "base": {
                        "width": "40%",
                        "padding-left": "max(2rem, calc((100vw - var(--container-width)) / 2 + 2rem))",
                        "padding-right": "2rem",
                        "display": "flex",
                        "flex-direction": "column",
                        "gap": "1.5rem"

                    }
                },
                "MobileMenuButton": {
                    "__html": "button",
                    "base": {
                        "display": "none",
                        "background": "transparent",
                        "border": "2px solid var(--border-accent)",
                        "border-radius": "var(--border-radius-sm)",
                        "padding": "0.5rem 0.75rem",

                    }
                }
            },
            "mainContent": {
                "HeaderWrapper": {
                    "HeaderContainer": {
                        "LogoContainer": {
                            "LogoEmoji": {
                                "content": "🎤"
                            },
                            "LogoText": {
                                "content": "ШУТКИ",
                                "LogoAccent": {
                                    "content": "ПРО"
                                }
                            }
                        },
                        "NavContainer": {
                            "NavItemOne": {
                                "content": "Афиша"
                            },
                            "NavItemTwo": {
                                "content": "О комике"
                            },
                            "NavItemThree": {
                                "content": "Видео"
                            },
                            "NavItemFour": {
                                "content": "Контакты"
                            }
                        },
                        "HeaderActions": {
                            "HeaderCta": {
                                "content": "Билеты"
                            },
                            "MobileMenuButton": {
                                "content": "☰ МЕНЮ"
                            }
                        }
                    }
                }
            }
        },
        "Hero": {
            "styles": {
                "HeroSection": {
                    "__html": "section",
                    "base": {
                        "width": "100%",
                        "min-height": "100vh",
                        "display": "flex",
                        "align-items": "center",

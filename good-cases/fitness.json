{
    "globalCssTokens": {
        "base": {
            "--transition-smooth": "0.25s cubic-bezier(0.4, 0, 0.2, 1)",
            "--border-radius-sm": "0.75rem",
            "--border-radius-md": "1.5rem",
            "--border-radius-lg": "3rem",
            "--border-radius-full": "9999px",
            "--font-main": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
            "--font-display": "'Clash Display', 'Inter', sans-serif",
            "--container-width": "1280px"
        },
        "light": {
            "--primary": "#0f4c5c",
            "--primary-light": "#1a6b80",
            "--accent": "#f46036",
            "--accent-soft": "#ffd5c2",
            "--background": "#ffffff",
            "--background-alt": "#f8fbfa",
            "--surface": "#ffffff",
            "--text-main": "#1e293b",
            "--text-muted": "#475569",
            "--border-light": "#e2e8f0",
            "--shadow-elevated": "0 20px 25px -5px rgba(15, 76, 92, 0.05), 0 10px 10px -5px rgba(15, 76, 92, 0.02)",
            "--gradient-hero": "linear-gradient(135deg, #f0f9f5 0%, #e0f2e9 100%)"
        },
        "dark": {
            "--primary": "#2a9d8f",
            "--primary-light": "#45c4b0",
            "--accent": "#f4a261",
            "--accent-soft": "#3a2c26",
            "--background": "#0f172a",
            "--background-alt": "#1e293b",
            "--surface": "#1e293b",
            "--text-main": "#f8fafc",
            "--text-muted": "#94a3b8",
            "--border-light": "#334155",
            "--shadow-elevated": "0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.1)",
            "--gradient-hero": "linear-gradient(135deg, #0f172a 0%, #1e293b 100%)"
        }
    },
    "sections": {
        "Header": {
            "styles": {
                "HeaderWrapper": {
                    "__html": "header",
                    "position": "sticky",
                    "top": "0",
                    "z-index": "50",
                    "background": "rgba(255, 255, 255, 0.8)",
                    "backdrop-filter": "blur(12px)",
                    "border-bottom": "1px solid var(--border-light)",
                    "padding": "1rem 2rem",
                    "font-family": "var(--font-main)"
                },
                "HeaderContainer": {
                    "__html": "nav",
                    "max-width": "var(--container-width)",
                    "margin": "0 auto",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "space-between"
                },
                "LogoContainer": {
                    "__html": "div",
                    "display": "flex",
                    "align-items": "center",
                    "gap": "0.5rem"
                },
                "LogoIcon": {
                    "__html": "div",
                    "width": "2rem",
                    "height": "2rem",
                    "background": "var(--primary)",
                    "border-radius": "var(--border-radius-sm)",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "center",
                    "color": "white",
                    "font-weight": "700"
                },
                "LogoText": {
                    "__html": "span",
                    "font-size": "1.5rem",
                    "font-weight": "700",
                    "color": "var(--text-main)",
                    "font-family": "var(--font-display)",
                    "letter-spacing": "-0.02em"
                },
                "NavList": {
                    "__html": "ul",
                    "display": "flex",
                    "gap": "2.5rem",
                    "list-style": "none",
                    "margin": "0",
                    "padding": "0"
                },
                "NavItem": {
                    "__html": "li",
                    "color": "var(--text-muted)",
                    "font-weight": "500",
                    "cursor": "pointer",
                    "transition": "color var(--transition-smooth)",
                    "font-size": "1rem"
                },
                "ActionButton": {
                    "__html": "button",
                    "background": "var(--primary)",
                    "color": "white",
                    "border": "none",
                    "border-radius": "var(--border-radius-full)",
                    "padding": "0.75rem 1.75rem",
                    "font-weight": "600",
                    "font-size": "0.95rem",
                    "cursor": "pointer",
                    "transition": "background var(--transition-smooth)",
                    "font-family": "var(--font-main)"
                }
            },
            "mainContent": {
                "HeaderWrapper": {
                    "HeaderContainer": {
                        "LogoContainer": {
                            "LogoIcon": {
                                "content": "F"
                            },
                            "LogoText": {
                                "content": "FlexLab"
                            }
                        },
                        "NavList": {
                            "NavItem": {
                                "content": "Программы"
                            },
                            "NavItem": {
                                "content": "Расписание"
                            },
                            "NavItem": {
                                "content": "Тренеры"
                            },
                            "NavItem": {
                                "content": "Цены"
                            }
                        },
                        "ActionButton": {
                            "content": "Записаться"
                        }
                    }
                }
            }
        },
        "Hero": {
            "styles": {
                "HeroSection": {
                    "__html": "section",
                    "width": "100%",
                    "padding": "4rem 2rem 6rem",
                    "background": "var(--gradient-hero)",
                    "position": "relative",
                    "overflow": "hidden",
                    "font-family": "var(--font-main)"
                },
                "HeroContainer": {
                    "__html": "div",
                    "max-width": "var(--container-width)",
                    "margin": "0 auto",
                    "display": "grid",
                    "grid-template-columns": "1fr 1.1fr",
                    "gap": "4rem",
                    "align-items": "center"
                },
                "HeroContent": {
                    "__html": "div",
                    "display": "flex",
                    "flex-direction": "column",
                    "gap": "1.75rem"
                },
                "HeroBadge": {
                    "__html": "span",
                    "display": "inline-block",
                    "background": "var(--accent-soft)",
                    "color": "var(--accent)",
                    "padding": "0.4rem 1rem",
                    "border-radius": "var(--border-radius-full)",
                    "font-weight": "600",
                    "font-size": "0.9rem",
                    "width": "fit-content"
                },
                "HeroTitle": {
                    "__html": "h1",
                    "font-family": "var(--font-display)",
                    "font-size": "clamp(3rem, 6vw, 4.5rem)",
                    "font-weight": "700",
                    "line-height": "1.1",
                    "letter-spacing": "-0.02em",
                    "color": "var(--text-main)",
                    "margin": "0"
                },
                "HeroDescription": {
                    "__html": "p",
                    "font-size": "1.2rem",
                    "line-height": "1.6",
                    "color": "var(--text-muted)",
                    "margin": "0",
                    "max-width": "90%"
                },
                "HeroCtaGroup": {
                    "__html": "div",
                    "display": "flex",
                    "gap": "1rem",
                    "margin-top": "1rem"
                },
                "PrimaryButton": {
                    "__html": "button",
                    "background": "var(--primary)",
                    "color": "white",
                    "border": "none",
                    "border-radius": "var(--border-radius-full)",
                    "padding": "1rem 2.5rem",
                    "font-weight": "600",
                    "font-size": "1.1rem",
                    "cursor": "pointer",
                    "transition": "all var(--transition-smooth)",
                    "box-shadow": "var(--shadow-elevated)"
                },
                "SecondaryButton": {
                    "__html": "button",
                    "background": "transparent",
                    "color": "var(--text-main)",
                    "border": "1px solid var(--border-light)",
                    "border-radius": "var(--border-radius-full)",
                    "padding": "1rem 2.5rem",
                    "font-weight": "600",
                    "font-size": "1.1rem",
                    "cursor": "pointer",
                    "transition": "all var(--transition-smooth)"
                },
                "HeroStats": {
                    "__html": "div",
                    "display": "flex",
                    "gap": "2.5rem",
                    "margin-top": "2rem"
                },
                "StatItem": {
                    "__html": "div",
                    "display": "flex",
                    "flex-direction": "column",
                    "gap": "0.25rem"
                },
                "StatValue": {
                    "__html": "span",
                    "font-size": "1.75rem",
                    "font-weight": "700",
                    "color": "var(--text-main)",
                    "font-family": "var(--font-display)"
                },
                "StatLabel": {
                    "__html": "span",
                    "color": "var(--text-muted)",
                    "font-size": "0.95rem"
                },
                "HeroVisual": {
                    "__html": "div",
                    "background": "var(--primary-light)",
                    "border-radius": "var(--border-radius-lg)",
                    "height": "480px",
                    "width": "100%",
                    "position": "relative",
                    "box-shadow": "var(--shadow-elevated)"
                }
            },
            "mainContent": {
                "HeroSection": {
                    "HeroContainer": {
                        "HeroContent": {
                            "HeroBadge": {
                                "content": "✨ Тренируйся с лучшими"
                            },
                            "HeroTitle": {
                                "content": "Прокачай своё тело и дух"
                            },
                            "HeroDescription": {
                                "content": "FlexLab — это пространство, где фитнес встречается с удовольствием. Индивидуальные программы, современные тренажеры и заботливые тренеры."
                            },
                            "HeroCtaGroup": {
                                "PrimaryButton": {
                                    "content": "Начать тренировку"
                                },
                                "SecondaryButton": {
                                    "content": "Смотреть видео-тур"
                                }
                            },
                            "HeroStats": {
                                "StatItem": {
                                    "StatValue": {
                                        "content": "1200+"
                                    },
                                    "StatLabel": {
                                        "content": "Довольных клиентов"
                                    }
                                },
                                "StatItem": {
                                    "StatValue": {
                                        "content": "25"
                                    },
                                    "StatLabel": {
                                        "content": "Тренировочных зон"
                                    }
                                },
                                "StatItem": {
                                    "StatValue": {
                                        "content": "4.9"
                                    },
                                    "StatLabel": {
                                        "content": "Средний рейтинг"
                                    }
                                }
                            }
                        },
                        "HeroVisual": {
                            "content": " "
                        }
                    }
                }
            }
        },
        "Programs": {
            "styles": {
                "ProgramsSection": {
                    "__html": "section",
                    "padding": "6rem 2rem",
                    "background": "var(--background)",
                    "font-family": "var(--font-main)"
                },
                "ProgramsContainer": {
                    "__html": "div",
                    "max-width": "var(--container-width)",
                    "margin": "0 auto"
                },
                "SectionHeader": {
                    "__html": "div",
                    "text-align": "center",
                    "margin-bottom": "4rem"
                },
                "SectionTitle": {
                    "__html": "h2",
                    "font-family": "var(--font-display)",
                    "font-size": "clamp(2rem, 4vw, 3rem)",
                    "color": "var(--text-main)",
                    "margin-bottom": "1rem",
                    "letter-spacing": "-0.02em"
                },
                "SectionSubtitle": {
                    "__html": "p",
                    "font-size": "1.2rem",
                    "color": "var(--text-muted)",
                    "max-width": "600px",
                    "margin": "0 auto"
                },
                "ProgramsGrid": {
                    "__html": "div",
                    "display": "grid",
                    "grid-template-columns": "repeat(3, 1fr)",
                    "gap": "2rem"
                },
                "ProgramCard": {
                    "__html": "article",
                    "background": "var(--surface)",
                    "border-radius": "var(--border-radius-md)",
                    "padding": "2rem",
                    "box-shadow": "var(--shadow-elevated)",
                    "border": "1px solid var(--border-light)",
                    "transition": "transform var(--transition-smooth)"
                },
                "CardIcon": {
                    "__html": "div",
                    "width": "3.5rem",
                    "height": "3.5rem",
                    "background": "var(--accent-soft)",
                    "border-radius": "var(--border-radius-sm)",
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "center",
                    "margin-bottom": "1.5rem",
                    "color": "var(--accent)",
                    "font-weight": "700"
                },
                "CardTitle": {
                    "__html": "h3",
                    "font-size": "1.5rem",
                    "font-weight": "600",
                    "margin-bottom": "1rem",
                    "color": "var(--text-main)",
                    "font-family": "var(--font-display)"
                },
                "CardDescription": {
                    "__html": "p",
                    "color": "var(--text-muted)",
                    "line-height": "1.6",
                    "margin": "0"
                }
            },
            "mainContent": {
                "ProgramsSection": {
                    "ProgramsContainer": {
                        "SectionHeader": {
                            "SectionTitle": {
                                "content": "Выбери свое направление"
                            },
                            "SectionSubtitle": {
                                "content": "В FlexLab каждый найдет тренировку по душе. От расслабляющего стретчинга до интенсивного кроссфита."
                            }
                        },
                        "ProgramsGrid": {
                            "ProgramCard": {
                                "CardIcon": {
                                    "content": "🏋️"
                                },
                                "CardTitle": {
                                    "content": "Силовой тренинг"
                                },
                                "CardDescription": {
                                    "content": "Наращивание мышечной массы и силы под контролем опытных наставников."
                                }
                            },
                            "ProgramCard": {
                                "CardIcon": {
                                    "content": "🧘"
                                },
                                "CardTitle": {
                                    "content": "Йога и Пилатес"
                                },
                                "CardDescription": {
                                    "content": "Гибкость, баланс и осознанность в комфортном зале с панорамными окнами."
                                }
                            },
                            "ProgramCard": {
                                "CardIcon": {
                                    "content": "🔥"
                                },
                                "CardTitle": {
                                    "content": "HIIT и Кардио"
                                },
                                "CardDescription": {
                                    "content": "Максимальное сжигание калорий и выносливость за минимальное время."
                                }
                            }
                        }
                    }
                }
            }
        },
        "Footer": {
            "styles": {
                "FooterWrapper": {
                    "__html": "footer",
                    "background": "var(--background-alt)",
                    "padding": "4rem 2rem 2rem",
                    "border-top": "1px solid var(--border-light)",
                    "font-family": "var(--font-main)"
                },
                "FooterContainer": {
                    "__html": "div",
                    "max-width": "var(--container-width)",
                    "margin": "0 auto"
                },
                "FooterContent": {
                    "__html": "div",
                    "display": "flex",
                    "justify-content": "space-between",
                    "align-items": "center",
                    "flex-wrap": "wrap",
                    "gap": "2rem"
                },
                "Copyright": {
                    "__html": "p",
                    "color": "var(--text-muted)",
                    "font-size": "0.95rem"
                },
                "FooterLinks": {
                    "__html": "div",
                    "display": "flex",
                    "gap": "2rem"
                },
                "FooterLink": {
                    "__html": "a",
                    "color": "var(--text-muted)",
                    "text-decoration": "none",
                    "font-size": "0.95rem",
                    "cursor": "pointer",
                    "transition": "color var(--transition-smooth)"
                }
            },
            "mainContent": {
                "FooterWrapper": {
                    "FooterContainer": {
                        "FooterContent": {
                            "Copyright": {
                                "content": "© 2026 FlexLab. Все права защищены."
                            },
                            "FooterLinks": {
                                "FooterLink": {
                                    "content": "Политика конфиденциальности"
                                },
                                "FooterLink": {
                                    "content": "Условия использования"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
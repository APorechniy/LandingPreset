{
    "globalCssTokens": {
        "base": {
            "--transition-smooth": "0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
            "--transition-slow": "0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94)",
            "--border-radius-sm": "0.5rem",
            "--border-radius-md": "1rem",
            "--border-radius-lg": "2rem",
            "--border-radius-xl": "4rem",
            "--font-main": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
            "--font-display": "'Cinzel', 'Times New Roman', serif",
            "--font-decor": "'Playfair Display', serif",
            "--container-width": "1280px",
            "--container-mobile-width": "768px"
        },
        "light": {
            "--primary": "#0a1c3a",
            "--primary-light": "#1a3a6e",
            "--accent": "#c9a13b",
            "--accent-glow": "#e8c56d",
            "--accent-secondary": "#2a9d8f",
            "--background": "#f9f7f2",
            "--background-alt": "#f0ece1",
            "--surface": "#ffffff",
            "--surface-elevated": "#fcfaf5",
            "--text-main": "#1a1a1a",
            "--text-muted": "#4a4a4a",
            "--text-dim": "#7a7a7a",
            "--border-light": "#e0d8cc",
            "--border-gold": "#c9a13b",
            "--shadow-sm": "0 4px 12px rgba(10, 28, 58, 0.04)",
            "--shadow-md": "0 12px 28px rgba(10, 28, 58, 0.08)",
            "--shadow-lg": "0 24px 48px rgba(10, 28, 58, 0.12)",
            "--shadow-gold": "0 16px 40px rgba(201, 161, 59, 0.15)",
            "--gradient-hero": "linear-gradient(135deg, #0a1c3a 0%, #1a3a6e 50%, #0a1c3a 100%)",
            "--gradient-card": "linear-gradient(145deg, #ffffff 0%, #fcfaf5 100%)",
            "--pattern-islamic": "repeating-linear-gradient(45deg, rgba(201, 161, 59, 0.05) 0px, rgba(201, 161, 59, 0.05) 2px, transparent 2px, transparent 8px)"
        },
        "dark": {
            "--primary": "#050d1a",
            "--primary-light": "#0a1c3a",
            "--accent": "#d4af37",
            "--accent-glow": "#f3d779",
            "--accent-secondary": "#2a9d8f",
            "--background": "#0d1117",
            "--background-alt": "#131a24",
            "--surface": "#182230",
            "--surface-elevated": "#1e2a3a",
            "--text-main": "#f0f0f0",
            "--text-muted": "#b0b0b0",
            "--text-dim": "#707070",
            "--border-light": "#2a3a4a",
            "--border-gold": "#d4af37",
            "--shadow-sm": "0 4px 12px rgba(0, 0, 0, 0.3)",
            "--shadow-md": "0 12px 28px rgba(0, 0, 0, 0.4)",
            "--shadow-lg": "0 24px 48px rgba(0, 0, 0, 0.5)",
            "--shadow-gold": "0 16px 40px rgba(212, 175, 55, 0.2)",
            "--gradient-hero": "linear-gradient(135deg, #050d1a 0%, #0a1c3a 50%, #050d1a 100%)",
            "--gradient-card": "linear-gradient(145deg, #182230 0%, #1e2a3a 100%)",
            "--pattern-islamic": "repeating-linear-gradient(45deg, rgba(212, 175, 55, 0.08) 0px, rgba(212, 175, 55, 0.08) 2px, transparent 2px, transparent 8px)"
        }
    },
    "sections": {
        "Hero": {
            "styles": {
                "HeroSection": {
                    "__html": "section",
                    "base": {
                        "width": "100%",
                        "min-height": "100vh",
                        "display": "flex",
                        "align-items": "center",
                        "padding": "8rem 2rem 4rem",
                        "background": "var(--gradient-hero)",
                        "position": "relative",
                        "overflow": "hidden",
                        "font-family": "var(--font-main)"
                    },
                    "mobile": {
                        "flex-direction": "column",
                        "padding": "4rem 1rem 2rem"
                    }
                },
                "HeroContainer": {
                    "__html": "div",
                    "base": {
                        "max-width": "var(--container-width)",
                        "margin": "0 auto",
                        "width": "100%",
                        "position": "relative",
                        "z-index": "2"
                    },
                    "mobile": {
                        "max-width": "var(--container-mobile-width)"
                    }
                },
                "HeroContent": {
                    "__html": "div",
                    "base": {
                        "display": "flex",
                        "flex-direction": "column",
                        "align-items": "center",
                        "text-align": "center"
                    }
                },
                "HeroTitle": {
                    "__html": "h1",
                    "base": {
                        "font-family": "var(--font-display)",
                        "font-size": "clamp(3.5rem, 8vw, 6rem)",
                        "font-weight": "700",
                        "line-height": "1.1",
                        "color": "var(--text-main)",
                        "margin": "0 0 1.5rem",
                        "text-transform": "uppercase",
                        "letter-spacing": "4px",
                        "max-width": "1100px"
                    },
                    "mobile": {}
                },
                "HeroTitleGold": {
                    "__html": "span",
                    "base": {
                        "color": "var(--accent)",
                        "text-shadow": "0 0 20px rgba(201, 161, 59, 0.5)"
                    }
                }
            },
            "mainContent": {
                "HeroSection": {
                    "HeroContainer": {
                        "HeroContent": {
                            "HeroTitle": {
                                "content": "Samarkand ",
                                "HeroTitleGold": {
                                    "content": "Chess Masters"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
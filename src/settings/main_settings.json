{
    "meta": {
        "title": "TeaFlow | Премиальный чай со всего мира",
        "description": "Откройте вкус настоящего чая. Ручной сбор, доставка по России.",
        "robots": {
            "index": true,
            "follow": true,
            "googleBot": {
                "index": true,
                "follow": true,
                "max-video-preview": -1,
                "max-image-preview": "large",
                "max-snippet": -1
            }
        },
        "openGraph": {
            "title": "TeaFlow | Премиальный чай со всего мира",
            "description": "Откройте вкус настоящего чая. Ручной сбор, доставка по России.",
            "url": "https://teaflow.ru",
            "siteName": "TeaFlow",
            "images": [
                {
                    "url": "https://teaflow.ru/images/og-image.jpg",
                    "width": 1200,
                    "height": 630,
                    "alt": "TeaFlow - премиальный чай"
                }
            ],
            "locale": "ru_RU",
            "type": "website"
        },
        "icons": {
            "icon": [
                {
                    "url": "https://teaflow.ru/favicon.ico",
                    "sizes": "any"
                },
                {
                    "url": "https://teaflow.ru/favicon-16x16.png",
                    "sizes": "16x16",
                    "type": "image/png"
                },
                {
                    "url": "https://teaflow.ru/favicon-32x32.png",
                    "sizes": "32x32",
                    "type": "image/png"
                }
            ],
            "apple": "https://teaflow.ru/apple-touch-icon.png"
        },
        "appleWebApp": {
            "title": "TeaFlow",
            "statusBarStyle": "black-translucent"
        }
    },
    "globalCssTokens": {
        "base": {
            "--transition-smooth": "0.4s ease",
            "--border-radius-sm": "8px",
            "--border-radius-md": "16px",
            "--border-radius-lg": "24px",
            "--font-main": "'Inter', sans-serif",
            "--font-display": "'Cormorant Garamond', serif",
            "--container-width": "1200px"
        },
        "light": {
            "--primary": "#1a3320",
            "--accent": "#c9a13b",
            "--accent-soft": "#fdf8ee",
            "--background": "#fdfbf9",
            "--surface": "#ffffff",
            "--text-main": "#1a3320",
            "--text-muted": "#5a6a55",
            "--border-light": "#e0e8dd",
            "--shadow-md": "0 8px 30px rgba(26, 51, 32, 0.08)",
            "--gradient-hero": "linear-gradient(135deg, #fdfbf9 0%, #f5ede1 100%)"
        },
        "dark": {
            "--primary": "#e8f0e0",
            "--accent": "#d4af37",
            "--accent-soft": "#2d2410",
            "--background": "#0f1a10",
            "--surface": "#1a2a1a",
            "--text-main": "#e8f0e0",
            "--text-muted": "#a0b0a0",
            "--border-light": "#2a3a2a",
            "--shadow-md": "0 8px 30px rgba(0, 0, 0, 0.4)",
            "--gradient-hero": "linear-gradient(135deg, #0f1a10 0%, #1a2a1a 100%)"
        }
    },
    "sections": {
        "Hero": {
            "styles": {
                "heroSection": {
                    "base": {
                        "width": "100%",
                        "min-height": "100vh",
                        "display": "flex",
                        "align-items": "center",
                        "justify-content": "center",
                        "padding": "4rem 2rem",
                        "background": "var(--gradient-hero)",
                        "font-family": "var(--font-main)",
                        "text-align": "center",
                        "animation": "fadeIn 0.6s ease-out"
                    },
                    "mobile": {
                        "padding": "3rem 1rem"
                    }
                },
                "heroContainer": {
                    "base": {
                        "max-width": "600px",
                        "margin": "0 auto",
                        "display": "flex",
                        "flex-direction": "column",
                        "align-items": "center",
                        "gap": "1.5rem"
                    },
                    "mobile": {
                        "gap": "1rem"
                    }
                },
                "heroIcon": {
                    "base": {
                        "font-size": "4rem",
                        "animation": "float 3s ease-in-out infinite"
                    },
                    "mobile": {
                        "font-size": "3rem"
                    }
                },
                "heroTitle": {
                    "base": {
                        "font-family": "var(--font-display)",
                        "font-size": "clamp(2.5rem, 6vw, 4rem)",
                        "font-weight": "700",
                        "color": "var(--text-main)",
                        "line-height": "1.15",
                        "margin": "0"
                    },
                    "mobile": {
                        "font-size": "clamp(2rem, 10vw, 3rem)"
                    }
                },
                "heroTitleAccent": {
                    "base": {
                        "display": "block",
                        "color": "var(--accent)"
                    },
                    "mobile": {}
                },
                "heroDescription": {
                    "base": {
                        "font-size": "1.15rem",
                        "line-height": "1.7",
                        "color": "var(--text-muted)",
                        "max-width": "450px"
                    },
                    "mobile": {
                        "font-size": "1rem"
                    }
                },
                "heroButton": {
                    "base": {
                        "display": "inline-block",
                        "background": "var(--accent)",
                        "color": "white",
                        "padding": "1rem 2.5rem",
                        "border-radius": "var(--border-radius-sm)",
                        "font-weight": "600",
                        "font-size": "1rem",
                        "cursor": "pointer",
                        "border": "none",
                        "text-decoration": "none",
                        "transition": "opacity var(--transition-smooth)",
                        "animation": "fadeInUp 0.6s ease-out 0.3s both"
                    },
                    "mobile": {
                        "padding": "0.85rem 2rem"
                    }
                },
                "__keyframes": {
                    "fadeIn": {
                        "from": {
                            "opacity": 0
                        },
                        "to": {
                            "opacity": 1
                        }
                    },
                    "fadeInUp": {
                        "from": {
                            "opacity": 0,
                            "transform": "translateY(20px)"
                        },
                        "to": {
                            "opacity": 1,
                            "transform": "translateY(0)"
                        }
                    },
                    "float": {
                        "0%": {
                            "transform": "translateY(0)"
                        },
                        "50%": {
                            "transform": "translateY(-10px)"
                        },
                        "100%": {
                            "transform": "translateY(0)"
                        }
                    }
                }
            },
            "mainContent": {
                "tag": "section",
                "className": "heroSection",
                "props": {
                    "id": "hero"
                },
                "childrens": [
                    {
                        "tag": "div",
                        "className": "heroContainer",
                        "childrens": [
                            {
                                "tag": "div",
                                "className": "heroIcon",
                                "content": "🍃"
                            },
                            {
                                "tag": "h1",
                                "className": "heroTitle",
                                "childrens": [
                                    {
                                        "tag": "span",
                                        "content": "Чай, который "
                                    },
                                    {
                                        "tag": "span",
                                        "className": "heroTitleAccent",
                                        "content": "вдохновляет"
                                    }
                                ]
                            },
                            {
                                "tag": "p",
                                "className": "heroDescription",
                                "content": "Премиальные сорта со всего мира. Ручной сбор, бережная ферментация, доставка до двери."
                            },
                            {
                                "tag": "a",
                                "className": "heroButton",
                                "props": {
                                    "href": "#catalog"
                                },
                                "content": "Смотреть каталог"
                            }
                        ]
                    }
                ]
            }
        }
    }
}
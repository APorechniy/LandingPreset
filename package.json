{
  "name": "landing-preset",
  "version": "0.0.1",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "aigenerate:start": "node scripts/generate.js",
    "aigenerate:clear": "node scripts/clear.js",
    "aigenerate:reload": "yarn aigenerate:clear && yarn aigenerate:start"
  },
  "dependencies": {
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@yarnpkg/pnpify": "^4.1.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
